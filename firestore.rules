rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.token.email)).data;
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == 'ahmedzayn.x@gmail.com' ||
        (exists(/databases/$(database)/documents/users/$(request.auth.token.email)) && 
         get(/databases/$(database)/documents/users/$(request.auth.token.email)).data.role == 'Admin')
      );
    }

    function isSales() {
      return isSignedIn() && exists(/databases/$(database)/documents/users/$(request.auth.token.email)) && 
             get(/databases/$(database)/documents/users/$(request.auth.token.email)).data.role == 'Sales';
    }

    function isWorker() {
      return isSignedIn() && exists(/databases/$(database)/documents/users/$(request.auth.token.email)) && 
             get(/databases/$(database)/documents/users/$(request.auth.token.email)).data.role == 'Worker';
    }

    function isValidUser(data) {
      return data.keys().hasAll(['email', 'name', 'role', 'createdAt']) &&
             data.email is string &&
             data.name is string &&
             (data.role is string || data.role == null);
    }

    function isValidRole(data) {
      return data.keys().hasAll(['id', 'name', 'color', 'permissions']) &&
             data.id is string &&
             data.name is string &&
             data.color is string &&
             data.permissions is list;
    }

    // Users Collection
    match /users/{email} {
      allow read: if isSignedIn() && (request.auth.token.email == email || isAdmin());
      allow write: if isAdmin() && isValidUser(request.resource.data);
    }

    // Roles Collection
    match /roles/{roleId} {
      allow read: if isAdmin();
      allow write: if isAdmin() && isValidRole(request.resource.data);
    }

    // Orders Collection
    match /orders/{orderId} {
      allow read: if isSignedIn() && (isAdmin() || isSales() || isWorker());
      allow create: if isSignedIn() && (isAdmin() || isSales());
      allow update: if isSignedIn() && (
        isAdmin() || isSales() || 
        (isWorker() && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['phase', 'status', 'updatedAt']))
      );
      allow delete: if isAdmin();
    }

    // Connection Test
    match /test/connection {
      allow read: if true;
    }
  }
}
